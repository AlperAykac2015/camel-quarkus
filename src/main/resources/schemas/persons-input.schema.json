{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersonsInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["persons"],
  "properties": {
    "persons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "firstName", "lastName", "email", "age"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "firstName": {
            "type": "string",
            "minLength": 1
          },
          "lastName": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "age": {
            "type": "integer",
            "minimum": 1,
            "exclusiveMaximum": 100
          }
        }
      }
    }
  }
}
